import { useState, useCallback, useRef, useEffect } from "react";

const CRITERIA_PRESETS = {
  tech: ["Technical Skills", "Experience Level", "Education", "Projects & Portfolio", "Culture Fit"],
  sales: ["Sales Experience", "Industry Knowledge", "Communication", "Track Record", "Motivation"],
  generic: ["Relevant Experience", "Skills Match", "Education", "Soft Skills", "Overall Fit"],
};

// ── Helpers ──
function parseJSON(raw) {
  try {
    const cleaned = raw.replace(/```json|```/g, "").trim();
    return JSON.parse(cleaned);
  } catch {
    const match = raw.match(/\{[\s\S]*\}/);
    if (match) {
      try { return JSON.parse(match[0]); } catch { return null; }
    }
    return null;
  }
}

async function readFileAsBase64(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result.split(",")[1]);
    reader.onerror = () => reject(new Error("Failed to read file"));
    reader.readAsDataURL(file);
  });
}

async function readFileAsText(file) {
  return new Promise((resolve, reject) => {
    const reader = new FileReader();
    reader.onload = () => resolve(reader.result);
    reader.onerror = () => reject(new Error("Failed to read file"));
    reader.readAsText(file);
  });
}

async function extractFileContent(file) {
  if (file.type === "application/pdf") {
    const base64 = await readFileAsBase64(file);
    return { type: "document", source: { type: "base64", media_type: "application/pdf", data: base64 } };
  }
  const text = await readFileAsText(file);
  return { type: "text", text: `--- CV Content (${file.name}) ---\n${text}` };
}

async function callClaude(messages, systemPrompt) {
  const res = await fetch("https://api.anthropic.com/v1/messages", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
      model: "claude-sonnet-4-20250514",
      max_tokens: 1000,
      system: systemPrompt,
      messages,
    }),
  });
  const data = await res.json();
  if (data.error) throw new Error(data.error.message || "API error");
  return data.content.map((b) => b.text || "").join("\n");
}

// ── Score Bar ──
function ScoreBar({ score, label, small }) {
  const color =
    score >= 80 ? "#22c55e" : score >= 60 ? "#eab308" : score >= 40 ? "#f97316" : "#ef4444";
  return (
    <div style={{ marginBottom: small ? 6 : 10 }}>
      {label && (
        <div style={{ display: "flex", justifyContent: "space-between", fontSize: small ? 11 : 12, marginBottom: 3, fontFamily: "'DM Sans', sans-serif", color: "#94a3b8" }}>
          <span>{label}</span><span style={{ color, fontWeight: 700 }}>{score}/100</span>
        </div>
      )}
      <div style={{ height: small ? 4 : 6, background: "#1e293b", borderRadius: 99 }}>
        <div style={{ width: `${score}%`, height: "100%", background: color, borderRadius: 99, transition: "width 0.8s cubic-bezier(.4,0,.2,1)" }} />
      </div>
    </div>
  );
}

// ── Candidate Card ──
function CandidateCard({ candidate, rank, isExpanded, onToggle, onGenerateQuestions, loadingQuestions }) {
  const { name, overall_score, criteria_scores, summary, strengths, gaps, red_flags, interview_questions } = candidate;
  const medal = rank === 1 ? "🥇" : rank === 2 ? "🥈" : rank === 3 ? "🥉" : null;
  const tierColor =
    overall_score >= 80 ? "#22c55e" : overall_score >= 60 ? "#eab308" : overall_score >= 40 ? "#f97316" : "#ef4444";
  const tierLabel =
    overall_score >= 80 ? "Strong Match" : overall_score >= 60 ? "Potential" : overall_score >= 40 ? "Weak" : "No Match";

  return (
    <div
      style={{
        background: "linear-gradient(135deg, #0f172a 0%, #1e293b 100%)",
        border: `1px solid ${isExpanded ? tierColor + "66" : "#334155"}`,
        borderRadius: 16,
        padding: 24,
        cursor: "pointer",
        transition: "all 0.3s ease",
        position: "relative",
        overflow: "hidden",
      }}
      onClick={onToggle}
    >
      {rank <= 3 && (
        <div style={{ position: "absolute", top: -1, right: 20, background: tierColor, color: "#000", fontSize: 10, fontWeight: 800, padding: "4px 12px 6px", borderRadius: "0 0 8px 8px", letterSpacing: 1, textTransform: "uppercase", fontFamily: "'DM Sans', sans-serif" }}>
          TOP {rank}
        </div>
      )}

      {/* Header */}
      <div style={{ display: "flex", alignItems: "center", gap: 16, marginBottom: isExpanded ? 20 : 0 }}>
        <div style={{ width: 52, height: 52, borderRadius: 14, background: `linear-gradient(135deg, ${tierColor}33, ${tierColor}11)`, border: `2px solid ${tierColor}44`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 20, fontWeight: 800, color: tierColor, fontFamily: "'Space Mono', monospace", flexShrink: 0 }}>
          {medal || `#${rank}`}
        </div>
        <div style={{ flex: 1, minWidth: 0 }}>
          <div style={{ fontFamily: "'Space Mono', monospace", fontSize: 16, fontWeight: 700, color: "#f1f5f9", marginBottom: 2 }}>{name}</div>
          <div style={{ fontSize: 12, color: "#64748b", fontFamily: "'DM Sans', sans-serif" }}>{tierLabel} · Score {overall_score}/100</div>
        </div>
        <div style={{ textAlign: "right" }}>
          <div style={{ fontSize: 32, fontWeight: 800, color: tierColor, fontFamily: "'Space Mono', monospace", lineHeight: 1 }}>{overall_score}</div>
          <div style={{ fontSize: 10, color: "#64748b", fontFamily: "'DM Sans', sans-serif" }}>OVERALL</div>
        </div>
      </div>

      {/* Expanded */}
      {isExpanded && (
        <div style={{ borderTop: "1px solid #334155", paddingTop: 20, animation: "fadeIn 0.3s ease" }}>
          {/* Criteria Scores */}
          {criteria_scores && criteria_scores.length > 0 && (
            <div style={{ marginBottom: 20 }}>
              <div style={{ fontSize: 11, color: "#64748b", fontFamily: "'DM Sans', sans-serif", fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, marginBottom: 10 }}>Criteria Breakdown</div>
              {criteria_scores.map((c, i) => (
                <ScoreBar key={i} score={c.score} label={c.name} small />
              ))}
            </div>
          )}

          {/* Summary */}
          {summary && (
            <div style={{ background: "#0f172a", borderRadius: 10, padding: 14, marginBottom: 16, border: "1px solid #1e293b" }}>
              <div style={{ fontSize: 11, color: "#64748b", fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, marginBottom: 6, fontFamily: "'DM Sans', sans-serif" }}>Summary</div>
              <div style={{ fontSize: 13, color: "#cbd5e1", lineHeight: 1.5, fontFamily: "'DM Sans', sans-serif" }}>{summary}</div>
            </div>
          )}

          {/* Strengths & Gaps */}
          <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 16 }}>
            {strengths && strengths.length > 0 && (
              <div>
                <div style={{ fontSize: 11, color: "#22c55e", fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, marginBottom: 8, fontFamily: "'DM Sans', sans-serif" }}>✦ Strengths</div>
                {strengths.map((s, i) => (
                  <div key={i} style={{ fontSize: 12, color: "#94a3b8", marginBottom: 4, paddingLeft: 10, borderLeft: "2px solid #22c55e33", fontFamily: "'DM Sans', sans-serif" }}>{s}</div>
                ))}
              </div>
            )}
            {gaps && gaps.length > 0 && (
              <div>
                <div style={{ fontSize: 11, color: "#f97316", fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, marginBottom: 8, fontFamily: "'DM Sans', sans-serif" }}>⚠ Gaps</div>
                {gaps.map((g, i) => (
                  <div key={i} style={{ fontSize: 12, color: "#94a3b8", marginBottom: 4, paddingLeft: 10, borderLeft: "2px solid #f9731633", fontFamily: "'DM Sans', sans-serif" }}>{g}</div>
                ))}
              </div>
            )}
          </div>

          {/* Red Flags */}
          {red_flags && red_flags.length > 0 && (
            <div style={{ background: "#ef444411", border: "1px solid #ef444433", borderRadius: 10, padding: 12, marginBottom: 16 }}>
              <div style={{ fontSize: 11, color: "#ef4444", fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, marginBottom: 6, fontFamily: "'DM Sans', sans-serif" }}>🚩 Red Flags</div>
              {red_flags.map((r, i) => (
                <div key={i} style={{ fontSize: 12, color: "#fca5a5", marginBottom: 3, fontFamily: "'DM Sans', sans-serif" }}>• {r}</div>
              ))}
            </div>
          )}

          {/* Interview Questions */}
          {interview_questions && interview_questions.length > 0 ? (
            <div style={{ background: "#0f172a", borderRadius: 10, padding: 14, border: "1px solid #334155" }}>
              <div style={{ fontSize: 11, color: "#818cf8", fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, marginBottom: 10, fontFamily: "'DM Sans', sans-serif" }}>🎯 Suggested Interview Questions</div>
              {interview_questions.map((q, i) => (
                <div key={i} style={{ fontSize: 12, color: "#c7d2fe", marginBottom: 8, paddingLeft: 12, borderLeft: "2px solid #818cf844", fontFamily: "'DM Sans', sans-serif", lineHeight: 1.5 }}>
                  <span style={{ color: "#818cf8", fontWeight: 700 }}>Q{i + 1}.</span> {q}
                </div>
              ))}
            </div>
          ) : (
            <button
              onClick={(e) => { e.stopPropagation(); onGenerateQuestions(); }}
              disabled={loadingQuestions}
              style={{
                width: "100%",
                padding: "10px 16px",
                background: loadingQuestions ? "#1e293b" : "linear-gradient(135deg, #4f46e5, #7c3aed)",
                color: "#fff",
                border: "none",
                borderRadius: 10,
                fontSize: 13,
                fontWeight: 600,
                cursor: loadingQuestions ? "wait" : "pointer",
                fontFamily: "'DM Sans', sans-serif",
                transition: "all 0.2s",
              }}
            >
              {loadingQuestions ? "Generating questions..." : "🎯 Generate Interview Questions"}
            </button>
          )}
        </div>
      )}
    </div>
  );
}

// ── Main App ──
export default function CVScreener() {
  const [step, setStep] = useState("setup"); // setup | screening | results
  const [jobDesc, setJobDesc] = useState("");
  const [cvFiles, setCvFiles] = useState([]);
  const [criteria, setCriteria] = useState(CRITERIA_PRESETS.generic);
  const [customCriterion, setCustomCriterion] = useState("");
  const [candidates, setCandidates] = useState([]);
  const [expandedIdx, setExpandedIdx] = useState(null);
  const [progress, setProgress] = useState({ current: 0, total: 0, name: "" });
  const [error, setError] = useState(null);
  const [loadingQuestions, setLoadingQuestions] = useState(null);
  const fileInputRef = useRef(null);

  const handleFiles = (e) => {
    const files = Array.from(e.target.files).filter(
      (f) => f.type === "application/pdf" || f.type === "text/plain" || f.name.endsWith(".txt") || f.name.endsWith(".md")
    );
    setCvFiles((prev) => [...prev, ...files]);
  };

  const removeFile = (idx) => setCvFiles((prev) => prev.filter((_, i) => i !== idx));

  const addCriterion = () => {
    if (customCriterion.trim() && criteria.length < 8) {
      setCriteria((prev) => [...prev, customCriterion.trim()]);
      setCustomCriterion("");
    }
  };

  const removeCriterion = (idx) => setCriteria((prev) => prev.filter((_, i) => i !== idx));

  const screenCVs = async () => {
    if (!jobDesc.trim() || cvFiles.length === 0) {
      setError("Please provide a job description and at least one CV.");
      return;
    }
    setError(null);
    setStep("screening");
    const results = [];
    setProgress({ current: 0, total: cvFiles.length, name: "" });

    for (let i = 0; i < cvFiles.length; i++) {
      const file = cvFiles[i];
      setProgress({ current: i + 1, total: cvFiles.length, name: file.name });
      try {
        const fileContent = await extractFileContent(file);
        const systemPrompt = `You are an expert TA Ops CV screener. Analyze the provided CV against the job description.
Evaluate the candidate on these criteria: ${criteria.join(", ")}.
Respond ONLY with a JSON object (no markdown, no backticks, no preamble):
{
  "name": "Candidate full name from CV",
  "overall_score": 0-100,
  "criteria_scores": [{"name": "Criterion Name", "score": 0-100}],
  "summary": "2-3 sentence assessment",
  "strengths": ["strength 1", "strength 2", "strength 3"],
  "gaps": ["gap 1", "gap 2"],
  "red_flags": ["red flag if any"]
}
Be calibrated: 80+ = strong match, 60-79 = potential, 40-59 = weak, <40 = no match.`;

        const messages = [
          {
            role: "user",
            content: Array.isArray(fileContent)
              ? [fileContent, { type: "text", text: `Job Description:\n${jobDesc}` }]
              : [fileContent, { type: "text", text: `Job Description:\n${jobDesc}` }],
          },
        ];

        const raw = await callClaude(messages, systemPrompt);
        const parsed = parseJSON(raw);
        if (parsed) {
          parsed._fileName = file.name;
          results.push(parsed);
        } else {
          results.push({ name: file.name, overall_score: 0, summary: "Failed to parse response", strengths: [], gaps: ["Analysis failed"], red_flags: [], criteria_scores: [], _fileName: file.name });
        }
      } catch (err) {
        results.push({ name: file.name, overall_score: 0, summary: `Error: ${err.message}`, strengths: [], gaps: [], red_flags: ["Processing error"], criteria_scores: [], _fileName: file.name });
      }
    }

    results.sort((a, b) => b.overall_score - a.overall_score);
    setCandidates(results);
    setStep("results");
    setExpandedIdx(0);
  };

  const generateQuestions = async (idx) => {
    const c = candidates[idx];
    setLoadingQuestions(idx);
    try {
      const systemPrompt = `You are an expert interviewer. Based on the candidate profile and job context, generate 5 targeted interview questions that probe their specific gaps and validate their strengths.
Respond ONLY with a JSON object (no markdown, no backticks):
{"questions": ["question 1", "question 2", "question 3", "question 4", "question 5"]}
Make questions specific to THIS candidate — reference their actual experience and gaps.`;

      const messages = [
        {
          role: "user",
          content: `Job Description:\n${jobDesc}\n\nCandidate Profile:\nName: ${c.name}\nScore: ${c.overall_score}/100\nSummary: ${c.summary}\nStrengths: ${(c.strengths || []).join(", ")}\nGaps: ${(c.gaps || []).join(", ")}\nRed Flags: ${(c.red_flags || []).join(", ")}`,
        },
      ];

      const raw = await callClaude(messages, systemPrompt);
      const parsed = parseJSON(raw);
      if (parsed?.questions) {
        setCandidates((prev) => {
          const updated = [...prev];
          updated[idx] = { ...updated[idx], interview_questions: parsed.questions };
          return updated;
        });
      }
    } catch (err) {
      console.error("Question generation failed:", err);
    }
    setLoadingQuestions(null);
  };

  const reset = () => {
    setStep("setup");
    setCandidates([]);
    setExpandedIdx(null);
    setError(null);
  };

  return (
    <div style={{ minHeight: "100vh", background: "#020617", color: "#f1f5f9", fontFamily: "'DM Sans', sans-serif" }}>
      <style>{`
        @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap');
        @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
        @keyframes scan { 0% { left: -30%; } 100% { left: 130%; } }
        * { box-sizing: border-box; margin: 0; padding: 0; }
        textarea:focus, input:focus { outline: none; border-color: #6366f1 !important; }
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 99px; }
      `}</style>

      {/* Header */}
      <div style={{ padding: "32px 24px 20px", borderBottom: "1px solid #1e293b" }}>
        <div style={{ maxWidth: 720, margin: "0 auto" }}>
          <div style={{ display: "flex", alignItems: "center", gap: 12, marginBottom: 6 }}>
            <div style={{ width: 36, height: 36, borderRadius: 10, background: "linear-gradient(135deg, #6366f1, #a855f7)", display: "flex", alignItems: "center", justifyContent: "center", fontSize: 18 }}>⚡</div>
            <h1 style={{ fontFamily: "'Space Mono', monospace", fontSize: 22, fontWeight: 700, color: "#f1f5f9", letterSpacing: -0.5 }}>CV Screener</h1>
          </div>
          <p style={{ fontSize: 13, color: "#64748b", fontFamily: "'DM Sans', sans-serif" }}>
            AI-powered candidate screening · Upload CVs, get instant rankings & interview questions
          </p>
        </div>
      </div>

      <div style={{ maxWidth: 720, margin: "0 auto", padding: "24px 24px 60px" }}>

        {/* ── SETUP STEP ── */}
        {step === "setup" && (
          <div style={{ animation: "fadeIn 0.4s ease" }}>
            {/* Job Description */}
            <div style={{ marginBottom: 28 }}>
              <label style={{ display: "block", fontSize: 12, fontWeight: 700, color: "#94a3b8", textTransform: "uppercase", letterSpacing: 1, marginBottom: 8 }}>
                Job Description
              </label>
              <textarea
                value={jobDesc}
                onChange={(e) => setJobDesc(e.target.value)}
                placeholder="Paste the full job description here — title, requirements, nice-to-haves, team context..."
                rows={7}
                style={{ width: "100%", background: "#0f172a", border: "1px solid #334155", borderRadius: 12, padding: 16, color: "#e2e8f0", fontSize: 14, fontFamily: "'DM Sans', sans-serif", lineHeight: 1.6, resize: "vertical" }}
              />
            </div>

            {/* Criteria */}
            <div style={{ marginBottom: 28 }}>
              <label style={{ display: "block", fontSize: 12, fontWeight: 700, color: "#94a3b8", textTransform: "uppercase", letterSpacing: 1, marginBottom: 8 }}>
                Evaluation Criteria
              </label>
              <div style={{ display: "flex", gap: 8, marginBottom: 12, flexWrap: "wrap" }}>
                {Object.entries(CRITERIA_PRESETS).map(([key, vals]) => (
                  <button
                    key={key}
                    onClick={() => setCriteria(vals)}
                    style={{ padding: "6px 14px", background: JSON.stringify(criteria) === JSON.stringify(vals) ? "#4f46e5" : "#1e293b", color: JSON.stringify(criteria) === JSON.stringify(vals) ? "#fff" : "#94a3b8", border: "1px solid #334155", borderRadius: 8, fontSize: 12, fontWeight: 600, cursor: "pointer", textTransform: "capitalize", fontFamily: "'DM Sans', sans-serif" }}
                  >
                    {key}
                  </button>
                ))}
              </div>
              <div style={{ display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 12 }}>
                {criteria.map((c, i) => (
                  <span key={i} style={{ display: "flex", alignItems: "center", gap: 6, background: "#1e293b", border: "1px solid #334155", borderRadius: 8, padding: "5px 12px", fontSize: 12, color: "#cbd5e1" }}>
                    {c}
                    <span onClick={() => removeCriterion(i)} style={{ cursor: "pointer", color: "#64748b", fontWeight: 700, fontSize: 14 }}>×</span>
                  </span>
                ))}
              </div>
              <div style={{ display: "flex", gap: 8 }}>
                <input
                  value={customCriterion}
                  onChange={(e) => setCustomCriterion(e.target.value)}
                  onKeyDown={(e) => e.key === "Enter" && addCriterion()}
                  placeholder="Add custom criterion..."
                  style={{ flex: 1, background: "#0f172a", border: "1px solid #334155", borderRadius: 8, padding: "8px 14px", color: "#e2e8f0", fontSize: 13, fontFamily: "'DM Sans', sans-serif" }}
                />
                <button onClick={addCriterion} style={{ padding: "8px 16px", background: "#1e293b", border: "1px solid #334155", borderRadius: 8, color: "#94a3b8", fontSize: 13, fontWeight: 600, cursor: "pointer" }}>+</button>
              </div>
            </div>

            {/* CV Upload */}
            <div style={{ marginBottom: 28 }}>
              <label style={{ display: "block", fontSize: 12, fontWeight: 700, color: "#94a3b8", textTransform: "uppercase", letterSpacing: 1, marginBottom: 8 }}>
                Upload CVs ({cvFiles.length})
              </label>
              <div
                onClick={() => fileInputRef.current?.click()}
                style={{ border: "2px dashed #334155", borderRadius: 14, padding: "36px 24px", textAlign: "center", cursor: "pointer", transition: "border-color 0.2s", background: "#0f172a11" }}
                onMouseOver={(e) => (e.currentTarget.style.borderColor = "#6366f1")}
                onMouseOut={(e) => (e.currentTarget.style.borderColor = "#334155")}
              >
                <div style={{ fontSize: 28, marginBottom: 8 }}>📄</div>
                <div style={{ fontSize: 14, color: "#94a3b8", fontWeight: 500 }}>Drop PDFs or text files here</div>
                <div style={{ fontSize: 12, color: "#475569", marginTop: 4 }}>PDF, TXT, MD accepted</div>
                <input ref={fileInputRef} type="file" multiple accept=".pdf,.txt,.md" onChange={handleFiles} style={{ display: "none" }} />
              </div>
              {cvFiles.length > 0 && (
                <div style={{ marginTop: 12, display: "flex", flexDirection: "column", gap: 6 }}>
                  {cvFiles.map((f, i) => (
                    <div key={i} style={{ display: "flex", alignItems: "center", justifyContent: "space-between", background: "#0f172a", border: "1px solid #1e293b", borderRadius: 8, padding: "8px 14px" }}>
                      <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                        <span style={{ fontSize: 14 }}>{f.type === "application/pdf" ? "📕" : "📄"}</span>
                        <span style={{ fontSize: 13, color: "#cbd5e1" }}>{f.name}</span>
                        <span style={{ fontSize: 11, color: "#475569" }}>({(f.size / 1024).toFixed(0)} KB)</span>
                      </div>
                      <span onClick={() => removeFile(i)} style={{ cursor: "pointer", color: "#64748b", fontWeight: 700, fontSize: 16 }}>×</span>
                    </div>
                  ))}
                </div>
              )}
            </div>

            {error && (
              <div style={{ background: "#ef444422", border: "1px solid #ef444444", borderRadius: 10, padding: 12, marginBottom: 20, fontSize: 13, color: "#fca5a5" }}>
                {error}
              </div>
            )}

            {/* Launch */}
            <button
              onClick={screenCVs}
              style={{
                width: "100%",
                padding: "16px 24px",
                background: "linear-gradient(135deg, #4f46e5, #7c3aed)",
                color: "#fff",
                border: "none",
                borderRadius: 14,
                fontSize: 16,
                fontWeight: 700,
                cursor: "pointer",
                fontFamily: "'Space Mono', monospace",
                letterSpacing: 0.5,
                transition: "all 0.2s",
                boxShadow: "0 4px 24px #4f46e533",
              }}
            >
              ⚡ Screen {cvFiles.length} CV{cvFiles.length !== 1 ? "s" : ""}
            </button>
          </div>
        )}

        {/* ── SCREENING STEP ── */}
        {step === "screening" && (
          <div style={{ animation: "fadeIn 0.4s ease", textAlign: "center", paddingTop: 80 }}>
            <div style={{ position: "relative", width: 200, height: 6, background: "#1e293b", borderRadius: 99, margin: "0 auto 24px", overflow: "hidden" }}>
              <div style={{ width: `${(progress.current / progress.total) * 100}%`, height: "100%", background: "linear-gradient(90deg, #6366f1, #a855f7)", borderRadius: 99, transition: "width 0.5s ease" }} />
              <div style={{ position: "absolute", top: 0, height: "100%", width: "30%", background: "linear-gradient(90deg, transparent, #ffffff33, transparent)", animation: "scan 1.5s infinite" }} />
            </div>
            <div style={{ fontFamily: "'Space Mono', monospace", fontSize: 16, color: "#e2e8f0", marginBottom: 8 }}>
              Screening CV {progress.current}/{progress.total}
            </div>
            <div style={{ fontSize: 13, color: "#64748b", animation: "pulse 1.5s infinite" }}>
              Analyzing {progress.name}...
            </div>
          </div>
        )}

        {/* ── RESULTS STEP ── */}
        {step === "results" && (
          <div style={{ animation: "fadeIn 0.4s ease" }}>
            {/* Summary Bar */}
            <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 28 }}>
              {[
                { label: "Screened", value: candidates.length, icon: "📋" },
                { label: "Strong", value: candidates.filter((c) => c.overall_score >= 80).length, icon: "✅" },
                { label: "Potential", value: candidates.filter((c) => c.overall_score >= 60 && c.overall_score < 80).length, icon: "🔶" },
                { label: "Avg Score", value: Math.round(candidates.reduce((a, c) => a + c.overall_score, 0) / candidates.length), icon: "📊" },
              ].map((s, i) => (
                <div key={i} style={{ background: "#0f172a", border: "1px solid #1e293b", borderRadius: 12, padding: "14px 12px", textAlign: "center" }}>
                  <div style={{ fontSize: 18, marginBottom: 4 }}>{s.icon}</div>
                  <div style={{ fontFamily: "'Space Mono', monospace", fontSize: 22, fontWeight: 700, color: "#f1f5f9" }}>{s.value}</div>
                  <div style={{ fontSize: 10, color: "#64748b", textTransform: "uppercase", letterSpacing: 1 }}>{s.label}</div>
                </div>
              ))}
            </div>

            {/* Candidate Cards */}
            <div style={{ display: "flex", flexDirection: "column", gap: 16 }}>
              {candidates.map((c, i) => (
                <CandidateCard
                  key={i}
                  candidate={c}
                  rank={i + 1}
                  isExpanded={expandedIdx === i}
                  onToggle={() => setExpandedIdx(expandedIdx === i ? null : i)}
                  onGenerateQuestions={() => generateQuestions(i)}
                  loadingQuestions={loadingQuestions === i}
                />
              ))}
            </div>

            {/* Actions */}
            <div style={{ display: "flex", gap: 12, marginTop: 28 }}>
              <button
                onClick={reset}
                style={{ flex: 1, padding: "14px 20px", background: "#1e293b", border: "1px solid #334155", borderRadius: 12, color: "#94a3b8", fontSize: 14, fontWeight: 600, cursor: "pointer", fontFamily: "'DM Sans', sans-serif" }}
              >
                ← New Screening
              </button>
              <button
                onClick={() => {
                  const report = candidates.map((c, i) => `#${i+1} ${c.name} — Score: ${c.overall_score}/100\n${c.summary}\nStrengths: ${(c.strengths||[]).join(", ")}\nGaps: ${(c.gaps||[]).join(", ")}\n${(c.interview_questions||[]).length ? "Questions:\n" + c.interview_questions.map((q,j) => `  ${j+1}. ${q}`).join("\n") : ""}`).join("\n\n---\n\n");
                  navigator.clipboard?.writeText(report);
                }}
                style={{ flex: 1, padding: "14px 20px", background: "linear-gradient(135deg, #4f46e5, #7c3aed)", border: "none", borderRadius: 12, color: "#fff", fontSize: 14, fontWeight: 600, cursor: "pointer", fontFamily: "'DM Sans', sans-serif" }}
              >
                📋 Copy Report
              </button>
            </div>
          </div>
        )}
      </div>
    </div>
  );
}
