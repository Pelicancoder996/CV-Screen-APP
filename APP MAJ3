    };

    // Commerciaux
    const functionsCommerciaux = {
      "Business Developer Junior": { p25:30000, p50:35000, p75:40000 },
      "Business Developer Confirmé": { p25:38000, p50:42000, p75:48000 },
      "Ingénieur d’Affaires": { p25:45000, p50:50000, p75:60000 },
